                    <div class="stat-card">
                        <div class="stat-number counter" data-target="6">0</div>
                        <div class="stat-label">Years Experience</div>
                    </div>
                </div>

                <div class="col-md-3 col-6 reveal">
                    <div class="stat-card">
                        <div class="stat-number counter" data-target="75">0</div>
                        <div class="stat-label">Projects Delivered</div>
                    </div>
                </div>

                <div class="col-md-3 col-6 reveal">
                    <div class="stat-card">
                        <div class="stat-number counter" data-target="40">0</div>
                        <div class="stat-label">Clients Served</div>
                    </div>
                </div>

                <div class="col-md-3 col-6 reveal">
                    <div class="stat-card">
                        <div class="stat-number counter" data-target="100">0</div>
                        <div class="stat-label">Satisfaction %</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

