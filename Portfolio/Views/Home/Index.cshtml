<!-- HERO -->
<section class="portfolio-home-page hero-section">
    <div class="container">
        <div class="row align-items-center flex-column-reverse flex-lg-row g-5">
            <div class="col-lg-6 reveal">
                <h1 class="hero-title">
                    Hi, I'm <span>Shahbaz Idrees</span><br />
                    Creative Web Developer
                </h1>

                <div class="typing-text" id="typed-text"></div>

                <p class="hero-subtitle">
                    I build scalable, elegant, and high-performance web applications using ASP.NET and modern technologies with a strong focus on clean architecture, responsive design, and real business value.
                </p>

                <a href="https://github.com/shahbazidrees1212?tab=repositories" class="btn-main">
                    <i class="fas fa-briefcase"></i>
                    View Portfolio
                </a>
            </div>

            <div class="col-lg-6 text-center reveal">
