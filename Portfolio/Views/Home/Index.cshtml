@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const typedElement = document.getElementById("typed-text");
            const phrases = [
                "Senior .NET Engineer",
                "Backend Specialist",
                "Clean Architecture Expert",
                "Modern Web Developer"
            ];

            let phraseIndex = 0;
            let charIndex = 0;
            let isDeleting = false;
            let countersStarted = false;

            function startTypewriter() {
                if (!typedElement || !phrases.length) return;

                const currentPhrase = phrases[phraseIndex];
                typedElement.textContent = currentPhrase.substring(0, charIndex);

                if (!isDeleting && charIndex < currentPhrase.length) {
                    charIndex++;
                    setTimeout(startTypewriter, 90);
                    return;
                }

                if (!isDeleting && charIndex === currentPhrase.length) {
                    isDeleting = true;
                    setTimeout(startTypewriter, 1400);
                    return;
                }

                if (isDeleting && charIndex > 0) {
                    charIndex--;
                    setTimeout(startTypewriter, 50);
                    return;
                }

                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                setTimeout(startTypewriter, 250);
            }

            function revealElements() {
                const revealItems = document.querySelectorAll(".reveal");

                revealItems.forEach(function (item) {
                    const itemTop = item.getBoundingClientRect().top;
                    const visiblePoint = window.innerHeight - 100;

                    if (itemTop < visiblePoint) {
                        item.classList.add("active");
                    }
                });
            }

            function animateCounter(counter) {
                const target = parseInt(counter.dataset.target || "0", 10);
                let current = 0;
                const increment = Math.max(1, Math.ceil(target / 120));

                function update() {
                    current += increment;

                    if (current < target) {
                        counter.textContent = current;
                        requestAnimationFrame(update);
                    } else {
                        counter.textContent = target;
                    }
                }

                update();
            }

            function triggerCounters() {
                if (countersStarted) return;

                const statsSection = document.querySelector(".stats-section");
                if (!statsSection) return;

                const statsTop = statsSection.getBoundingClientRect().top;
                if (statsTop < window.innerHeight - 120) {
                    countersStarted = true;

                    document.querySelectorAll(".counter").forEach(function (counter) {
                        animateCounter(counter);
                    });

                    window.removeEventListener("scroll", triggerCounters);
                }
            }

            function initSwiper(selector, autoplayDelay) {
                const element = document.querySelector(selector);
                if (!element || typeof Swiper === "undefined") return;

                new Swiper(selector, {
                    slidesPerView: 1,
                    spaceBetween: 30,
                    loop: true,
                    speed: 900,
                    preloadImages: false,
                    lazy: true,
                    autoplay: {
                        delay: autoplayDelay,
                        disableOnInteraction: false
                    },
                    pagination: {
                        el: `${selector} .swiper-pagination`,
                        clickable: true
                    },
                    breakpoints: {
                        768: {
                            slidesPerView: 2
                        },
                        1200: {
                            slidesPerView: 3
                        }
                    }
                });
            }

            startTypewriter();
            revealElements();
            triggerCounters();

            window.addEventListener("scroll", revealElements, { passive: true });
            window.addEventListener("scroll", triggerCounters, { passive: true });

            initSwiper(".serviceSwiper", 2800);
            initSwiper(".projectSwiper", 3000);
        });
    </script>
   
}