<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My Portfolio</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Then your custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #0e0e17;
            color: #fff;
            margin: 0;
        }

        /* ================= NAVBAR ================= */

        .navbar {
            background: rgba(18, 20, 40, 0.85);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(139,92,246,0.25);
            padding: 16px 0;
            transition: 0.3s ease;
        }

            .navbar.scrolled {
                background: rgba(15, 17, 35, 0.98);
                box-shadow: 0 10px 40px rgba(0,0,0,0.6);
            }

        /* ===== Logo ===== */

        .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #8b5cf6, #d946ef);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            color: #fff;
            box-shadow: 0 6px 20px rgba(139,92,246,0.4);
            transition: 0.3s ease;
        }

        .logo-text {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: 0.5px;
        }

        .logo-gradient {
            background: linear-gradient(90deg, #8b5cf6, #d946ef);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .navbar-brand:hover .logo-icon {
            transform: scale(1.1);
            box-shadow: 0 10px 30px rgba(217,70,239,0.6);
        }

        /* ===== Nav Links ===== */

        .nav-link {
            color: #cbd5e1 !important;
            font-weight: 500;
            margin: 0 15px;
            position: relative;
            transition: 0.3s ease;
        }

            .nav-link:hover {
                color: #fff !important;
            }

            .nav-link.active {
                color: #fff !important;
            }

            .nav-link::after {
                content: "";
                position: absolute;
                bottom: -6px;
                left: 0;
                width: 0;
                height: 2px;
                background: linear-gradient(90deg, #8b5cf6, #d946ef);
                transition: 0.3s ease;
            }

            .nav-link:hover::after,
            .nav-link.active::after {
                width: 100%;
            }

        main {
            min-height: 85vh;
            padding-top: 40px;
        }

        /* ================= FOOTER ================= */

        footer {
            background: linear-gradient(135deg, #141933, #1b1f3f);
            border-top: 1px solid rgba(139,92,246,0.2);
            padding: 35px 0 18px;
        }

        .footer-title {
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 8px;
        }

        .footer-text {
            color: #9ca3af;
            font-size: 0.85rem;
            max-width: 450px;
            margin: 0 auto 15px;
        }

        .social-icons {
            margin-bottom: 10px;
        }

            .social-icons a {
                width: 36px;
                height: 36px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
                color: #cbd5e1;
                margin: 0 6px;
                font-size: 0.95rem;
                transition: 0.3s ease;
            }

                .social-icons a:hover {
                    background: linear-gradient(135deg, #8b5cf6, #d946ef);
                    color: #fff;
                    transform: translateY(-3px);
                }

        .copyright {
            font-size: 0.75rem;
            color: #6b7280;
            margin-top: 10px;
        }

        html {
            height: 100%;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-family: 'Poppins', sans-serif;
            background: #0e0e17;
            color: #fff;
            margin: 0;
        }

        main {
            flex: 1;
            padding-top: 20px; /* small space below navbar */
        }

        footer {
            margin-top: auto;
        }

    </style>

    @RenderSection("styles", required: false)
</head>
<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">

            <a class="navbar-brand d-flex align-items-center"
               href="@Url.Action("Index", "Home")">

                <div class="logo-icon">MP</div>

                <div class="logo-text ms-2">
                    My <span class="logo-gradient">Portfolio</span>
                </div>
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           href="@Url.Action("Index", "Home")">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")"
                           href="@Url.Action("About", "Home")">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Skills" ? "active" : "")"
                           href="@Url.Action("Skills", "Home")">Skills</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Projects" ? "active" : "")"
                           href="@Url.Action("Projects", "Home")">Projects</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Experience" ? "active" : "")"
                           href="@Url.Action("Experience", "Home")">Experience</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")"
                           href="@Url.Action("Contact", "Home")">Contact</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- ================= MAIN ================= -->
    <main>
        @RenderBody()
    </main>

    <!-- ================= FOOTER ================= -->
    <footer>
        <div class="container text-center">

            <div class="footer-title">Let’s Connect</div>

            <div class="footer-text">
                Building scalable web applications with clean architecture and modern UI.
            </div>

            <div class="social-icons">
                <a href="#"><i class="fab fa-github"></i></a>
                <a href="#"><i class="fab fa-linkedin"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
                <a href="#"><i class="fas fa-envelope"></i></a>
            </div>

            <div class="copyright">
                © @DateTime.Now.Year My Portfolio. All rights reserved.
            </div>

        </div>
    </footer>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.addEventListener("scroll", function () {
            const navbar = document.querySelector(".navbar");
            if (window.scrollY > 50) {
                navbar.classList.add("scrolled");
            } else {
                navbar.classList.remove("scrolled");
            }
        });
    </script>

    @RenderSection("scripts", required: false)

</body>
</html>
