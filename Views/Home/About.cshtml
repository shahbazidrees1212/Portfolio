@{
    ViewBag.Title = "About";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<div class="modern-about-page">
<section class="about-section">
    <div class="container">
        <div class="about-heading fade-up">
            <h1>About Me</h1>
            <p>Get to know more about my background, experience, and the professional values that shape my work.</p>
        </div>

        <div class="section-shell fade-up">
            <div class="row align-items-center g-5">
                <div class="col-lg-5 fade-up">
                    <div class="image-wrapper">
                        <div class="image-ring">
                            <img src="/Images/image.jfif" class="profile-img" alt="Shahbaz Idrees" />
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 fade-up">
                    <div class="about-panel">
                        <div class="about-content">
                            <h2>Hi, I'm <span>Shahbaz Idrees</span></h2>

                            <p>
                                I'm a passionate Full Stack ASP.NET Developer with 5+ years of experience building clean, scalable, and performance-driven web applications.
                            </p>

                            <p>
                                I specialize in ASP.NET MVC, .NET Core, C#, SQL Server, and modern frontend technologies, with a strong focus on clean architecture, maintainable code, and user-friendly digital experiences.
                            </p>

                            <div class="info-grid">
                                <div class="info-card">
                                    <strong>Name</strong>
                                    Shahbaz Idrees
                                </div>

                                <div class="info-card">
                                    <strong>Location</strong>
                                    Karachi, Pakistan
                                </div>

                                <div class="info-card">
                                    <strong>Degree</strong>
                                    Bachelor in Computer Science
                                </div>

                                <div class="info-card">
                                    <strong>Email</strong>
                                    shahbazidrees1212@example.com
                                </div>
                            </div>

                            <div class="resume-buttons">
                                <a href="~/files/Shahbaz_Idrees_Resume.pdf" target="_blank" class="btn-resume">
                                    <i class="fas fa-eye me-2"></i> View Resume
                                </a>

                                <a href="~/files/Shahbaz_Idrees_Resume.pdf" download class="btn-resume-outline">
                                    <i class="fas fa-download me-2"></i> Download Resume
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="values-section">
    <div class="container">
        <div class="values-heading-wrap fade-up">
            <h2 class="values-heading">My Core Values</h2>
            <p class="values-subtitle">
                These principles guide the way I design, build, and deliver quality digital solutions.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-4 fade-up">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                    <h4>Innovation</h4>
                    <p>Continuously learning, improving, and exploring smarter ways to solve real-world problems.</p>
                </div>
            </div>

            <div class="col-md-4 fade-up">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-code"></i>
                    </div>
                    <h4>Quality Code</h4>
                    <p>Writing clean, maintainable, and scalable systems that support long-term product growth.</p>
                </div>
            </div>

            <div class="col-md-4 fade-up">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4>Collaboration</h4>
                    <p>Working closely with teams and clients to create polished solutions with clarity and impact.</p>
                </div>
            </div>
        </div>
    </div>
</section>
</div>
@section scripts {
    <script>
        function revealFadeUpElements() {
            document.querySelectorAll('.fade-up').forEach(function (element) {
                if (element.getBoundingClientRect().top < window.innerHeight - 100) {
                    element.classList.add('active');
                }
            });
        }

        window.addEventListener('scroll', revealFadeUpElements);
        window.addEventListener('load', revealFadeUpElements);
        revealFadeUpElements();
    </script>
}